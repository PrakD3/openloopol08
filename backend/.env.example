# Vigilens Backend Environment Variables

# APP_MODE: "demo" | "real"
APP_MODE=demo

# Groq API
GROQ_API_KEY=
GROQ_ORCHESTRATOR_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# LangSmith Tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vigilens
LANGSMITH_TRACING_V2=true

# Google Cloud
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Transcription
WHISPER_USE_GROQ=true
WHISPER_USE_API=false

# Source Hunting
GOOGLE_VISION_API_KEY=
TINEYE_API_KEY=
YOUTUBE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
