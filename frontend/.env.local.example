# ============================================================
# Vigilens Environment Configuration
# Copy to .env.local and fill in your values
# ============================================================

# INFERENCE_MODE: "online" | "offline"
NEXT_PUBLIC_INFERENCE_MODE=offline

# APP_MODE: "demo" | "real"
NEXT_PUBLIC_APP_MODE=real

# Backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Groq API Key
GROQ_API_KEY=

# Hive AI
HIVE_API_KEY=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vigilens
LANGSMITH_TRACING_V2=true

# Together AI
TOGETHER_API_KEY=

# Google Vision API
GOOGLE_VISION_API_KEY=

# TinEye API
TINEYE_API_KEY=

# YouTube Data API v3
YOUTUBE_API_KEY=

# Shodan API
SHODAN_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ORCHESTRATOR_MODEL=llama3.3
OLLAMA_VISION_MODEL=llava:13b

# DeepSafe
DEEPSAFE_URL=http://localhost:8001

# Whisper
WHISPER_MODEL_SIZE=medium

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
