# ============================================================
# Vigilens Environment Configuration
# Copy to .env.local and fill in your values
# ============================================================

# INFERENCE_MODE: "online" | "offline"
NEXT_PUBLIC_INFERENCE_MODE=offline

# APP_MODE: "demo" | "real"
NEXT_PUBLIC_APP_MODE=real

# Backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Groq API Key
GROQ_API_KEY=

# Hive AI
HIVE_API_KEY=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vigilens
LANGSMITH_TRACING_V2=true

# Together AI
TOGETHER_API_KEY=

# Google Vision API
GOOGLE_VISION_API_KEY=

# TinEye API
TINEYE_API_KEY=

# YouTube Data API v3
YOUTUBE_API_KEY=

# Shodan API
SHODAN_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ORCHESTRATOR_MODEL=llama3.3
OLLAMA_VISION_MODEL=llava:13b

# DeepSafe
DEEPSAFE_URL=http://localhost:8001

# Whisper
WHISPER_MODEL_SIZE=medium

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── TASK 1: DEEPFAKE DETECTION ───────────────────────────────
# Online: Hive AI (100 req/day free) — https://thehive.ai
HIVE_API_KEY=

# Offline: DeepSafe Docker (set in docker-compose)
DEEPSAFE_URL=http://localhost:8001

# Fallback threshold for basic pixel-variance heuristic
DEEPFAKE_FALLBACK_THRESHOLD=0.65

# ── TASK 2: SOURCE HUNTER ────────────────────────────────────
# Google Vision API (1000 req/month free)
# https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=

# TinEye API (150 req/month free)
# https://services.tineye.com/TinEyeAPI
TINEYE_API_KEY=

# Bing Visual Search (free tier via Azure Cognitive)
# https://azure.microsoft.com/en-us/products/cognitive-services/bing-visual-search
BING_SEARCH_API_KEY=

# Wayback Machine — no key needed (free, public)
# WAYBACK_BASE_URL is hardcoded to http://archive.org/wayback/available

# ── TASK 3: CONTEXT ANALYSER ─────────────────────────────────
# Open-Meteo — no key needed (free, public)
# GDACS API — no key needed (free, public)
# OpenStreetMap Nominatim — no key needed (free, public)
# ClaimBuster API (free)
CLAIMBUSTER_API_KEY=

# ── TASK 4: API INTEGRATIONS ─────────────────────────────────
# YouTube Data API v3 (free with key)
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# X (Twitter) API v2 Bearer Token
# https://developer.x.com/en/docs/x-api
X_BEARER_TOKEN=

# yt-dlp is installed as a Python package — no key needed for metadata extraction
# Instagram, Twitter/X, TikTok metadata via yt-dlp (free, no key)

# ── NOTIFICATIONS: TWILIO SMS ────────────────────────────────
# Twilio free trial — https://www.twilio.com/try-twilio
# Free trial gives $15.50 credit, ~1000 SMS messages
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx    # Your Twilio trial number

# Notification config
NOTIFICATION_RADIUS_KM=50           # Alert users within this radius
NOTIFICATION_CONFIDENCE_THRESHOLD=85  # Min orchestrator score to trigger alert
NOTIFICATION_ENABLED=true           # Set false to disable all SMS in dev
